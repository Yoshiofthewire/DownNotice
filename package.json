{
  "name": "downnotice",
  "version": "1.0.1",
  "description": "Cross-platform desktop application that monitors RSS feeds for cloud provider outages",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack serve --config webpack.renderer.config.js\" \"wait-on http://localhost:9000 && electron .\"",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build": "npm run build:renderer && electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.downnotice.app",
    "productName": "DownNotice",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "build/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icons",
        "to": "icons"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/app-icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/app-icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "flatpak"
      ],
      "icon": "assets/icons/",
      "category": "Utility"
    },
    "flatpak": {
      "runtimeVersion": "23.08",
      "baseVersion": "23.08",
      "runtime": "org.freedesktop.Platform",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "fast-xml-parser": "^4.3.0",
    "node-fetch": "^2.7.0",
    "auto-launch": "^5.0.6"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.0",
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "babel-loader": "^9.1.0",
    "css-loader": "^6.8.0",
    "style-loader": "^3.3.0",
    "html-webpack-plugin": "^5.6.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0",
    "concurrently": "^8.2.0",
    "wait-on": "^7.2.0"
  },
  "license": "GPL-2.0"
}
